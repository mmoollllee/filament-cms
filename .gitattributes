# Keep dev-only scaffolding out of the Composer `--prefer-dist` archive so consuming
# apps don't pull the workbench app, test suite, docs and build tooling into vendor/.
/tests            export-ignore
/workbench        export-ignore
/docs             export-ignore
/bin              export-ignore
testbench.yaml    export-ignore
phpunit.xml.dist  export-ignore
package.json      export-ignore
.gitattributes    export-ignore
.gitignore        export-ignore
